class Solution:
    def processStr(self, s: str) -> str:
        result=""
        for ch in s:
            if ch=="*" and len(result)>=1:
                result=result[:-1]
            if ch=="#" and len(result)>=1:
                result+=result
            if ch=="%" and len(result)>=1:
                result=result[::-1]
            if "a"<=ch<="z":
                result+=ch
        return result
